# Application
APP_ENV=development
APP_NAME=Acadexa AI API

# Database (PostgreSQL / Neon). Use sslmode=require for Neon.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require

# Security
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI (OpenRouter) - Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx --- IGNORE ---
OPENROUTER_MODEL=google/gemini-2.5-flash

# CORS (comma separated)
CORS_ORIGINS=http://localhost:5173

# Cloudinary (optional - enables remote file storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=acadexa-ai

# Rate limiting + upload limits
AI_RATE_LIMIT=30/minute
MAX_UPLOAD_MB=20